# ── Django ─────────────────────────────────────────────
# Gere uma chave: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=troque-por-uma-chave-secreta
DEBUG=False
# Hosts permitidos, separados por vírgula
ALLOWED_HOSTS=localhost,127.0.0.1
# Origens confiáveis p/ CSRF (ex.: https://meudominio.com), separadas por vírgula
CSRF_TRUSTED_ORIGINS=

# ── Banco de dados (dj-database-url) ───────────────────
# Se omitido, usa SQLite local (db.sqlite3).
#
# PostgreSQL local (serviço `db` do docker-compose):
DATABASE_URL=postgres://akita:akita@db:5432/akita
#
# Supabase — conexão direta (porta 5432):
# DATABASE_URL=postgresql://postgres:SENHA@db.SEUREF.supabase.co:5432/postgres?sslmode=require
#
# Supabase — pooler de transação (porta 6543; o app já ajusta o modo pgBouncer):
# DATABASE_URL=postgresql://postgres.SEUREF:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?sslmode=require
#
# SQLite dentro do container (alternativa):
# DATABASE_URL=sqlite:////app/db.sqlite3

# ── Postgres (serviço `db` do docker-compose) ──────────
POSTGRES_DB=akita
POSTGRES_USER=akita
POSTGRES_PASSWORD=akita
